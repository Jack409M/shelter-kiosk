<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Leave Request</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 16px; color: #111; }
    .toolbar { margin-bottom: 12px; }
    button { padding: 7px 10px; border: 1px solid #333; background: #fff; border-radius: 6px; cursor: pointer; }
    .box { border: 2px solid #000; padding: 12px; margin-bottom: 12px; }
    h1 { margin: 0 0 8px 0; font-size: 20px; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 18px; font-size: 13px; }
    .label { font-weight: 700; }
    .line { border-bottom: 1px solid #000; min-height: 18px; padding-bottom: 2px; }
    .wide { grid-column: 1 / -1; }
    @media print { .toolbar { display: none; } body { margin: 0.5in; } }
  </style>
</head>
<body>

  <div class="toolbar">
    <button type="button" onclick="window.print()">Print</button>
    <button type="button" onclick="window.close()">Close</button>
  </div>

  <div class="box">
    <h1>Leave Request</h1>
    <div style="font-size:13px;">
      Shelter: {{ shelter }}<br>
      Printed: {{ printed_on }}
    </div>
  </div>

  <div class="box">
    <div class="grid">
      <div><span class="label">Resident</span><div class="line">{{ row.last_name }}, {{ row.first_name }}</div></div>
      <div><span class="label">Phone</span><div class="line">{{ row.resident_phone or "" }}</div></div>

      <div><span class="label">Destination</span><div class="line">{{ row.destination }}</div></div>
      <div><span class="label">Status</span><div class="line">{{ row.status }}</div></div>

      <div><span class="label">Leave date</span><div class="line">{{ fmt_date(row.leave_at) }}</div></div>
      <div><span class="label">Return date</span><div class="line">{{ fmt_date(row.return_at) }}</div></div>

      <div class="wide"><span class="label">Reason</span><div class="line">{{ row.reason or "" }}</div></div>
      <div class="wide"><span class="label">Resident notes</span><div class="line">{{ row.resident_notes or "" }}</div></div>
    </div>
  </div>

  <div class="box">
    <div class="grid">
      <div><span class="label">Submitted</span><div class="line">{{ fmt_dt(row.submitted_at) }}</div></div>
      <div><span class="label">Decided</span><div class="line">{{ fmt_dt(row.decided_at) }}</div></div>

      <div><span class="label">Case manager</span><div class="line">{{ row.decided_by_name or "" }}</div></div>
      <div><span class="label">Decision note</span><div class="line">{{ row.decision_note or "" }}</div></div>
    </div>
  </div>

  <div class="box">
    <div class="grid">
      <div><span class="label">Checked in at</span><div class="line">{{ fmt_dt(row.check_in_at) }}</div></div>
      <div><span class="label">Checked in by</span><div class="line">{{ row.check_in_by or "" }}</div></div>
    </div>
  </div>

  <div class="box">
    <div class="grid">
      <div class="wide"><span class="label">Staff signature</span><div class="line"></div></div>
      <div class="wide"><span class="label">Supervisor signature</span><div class="line"></div></div>
    </div>
  </div>

</body>
</html>
