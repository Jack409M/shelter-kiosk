# Required
FLASK_SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql://username:password@localhost:5432/shelter_kiosk

# Runtime and security
COOKIE_SECURE=1
CLOUDFLARE_ONLY=0
LOG_LEVEL=INFO
ENABLE_DEBUG_ROUTES=0
ENABLE_DANGEROUS_ADMIN_ROUTES=0

# Twilio feature flags
TWILIO_ENABLED=0
TWILIO_INBOUND_ENABLED=0
TWILIO_STATUS_ENABLED=0
TWILIO_STATUS_CALLBACK_URL=

# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional kiosk settings
KIOSK_PIN=

# Optional bootstrap admin
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Optional environment label
APP_ENV=development
